# This file itself — without this entry, Fern's next regen would replace
# the list below with an empty template, losing all preservation rules.
.fernignore

# Hand-written client extending the generated base
src/islo/client.py

# Hand-written extensions: token providers, exec helpers, file helpers
src/islo/custom/

# Project-level tooling that lives outside the generated SDK
Justfile
.pre-commit-config.yaml
scripts/

# Project tests (Fern would replace tests/ with its own scaffolding)
tests/

# Release workflow that fires after a Fern PR merges: lints, tests, builds,
# publishes to PyPI via Trusted Publishing, and pushes the v<version> tag.
.github/workflows/release.yml

# Own toolchain. Fern's Python generator emits a Poetry-flavored project
# (pyproject.toml [build-system] = poetry-core, ci.yml runs poetry publish).
# We want uv as the actual toolchain, so we keep these under our control
# and tell Fern to leave them alone on every regen.
pyproject.toml
uv.lock
.github/workflows/ci.yml

# Project's .gitignore — Fern would otherwise rewrite it (drops our entries
# for poetry.lock, requirements.txt, .astro/, node_modules/, .DS_Store).
.gitignore
